{
	"name": "nextstepbackend",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/server.ts",
		"build": "tsup src/server.ts --format esm --dts",
		"start": "bun run dist/server.js",
		"db:generate": "bunx prisma generate",
		"db:migrate": "bunx prisma migrate dev --schema=./prisma/schema.prisma",
		"db:studio": "bunx prisma studio --schema=./prisma/schema.prisma",
		"db:reset": "bunx prisma migrate reset --schema=./prisma/schema.prisma",
		"db:seed": "bun run prisma/seed.ts",
		"postinstall": "prisma generate"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bcryptjs": "^3.0.0",
		"@types/bun": "latest",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.7.0",
		"@types/nodemailer": "^8.0.0",
		"@types/uuid": "^11.0.0",
		"prisma": "^7.8.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1045.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"bcryptjs": "^3.0.3",
		"bullmq": "^5.76.6",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"ioredis": "^5.10.1",
		"jsonwebtoken": "^9.0.3",
		"morgan": "^1.10.1",
		"multer": "^2.1.1",
		"nodemailer": "^8.0.7",
		"pg": "^8.20.0",
		"rate-limiter-flexible": "^11.1.0",
		"uuid": "^14.0.0",
		"xss": "^1.0.15",
		"zod": "^4.4.3"
	}
}
