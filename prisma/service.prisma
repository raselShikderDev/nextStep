model ServiceCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services Service[]

  @@index([slug])
  @@index([isActive])
  @@map("service_categories")
}

model Service {
  id           String   @id @default(uuid())
  categoryId   String
  name         String
  slug         String   @unique
  description  String?
  features     String[] // bullet points of what's included
  deliverables String[] // what user receives on completion
  turnaround   String? // e.g. "2-3 business days"
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("BDT")
  formSchema   Json // dynamic form field definitions
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category ServiceCategory  @relation(fields: [categoryId], references: [id])
  requests ServiceRequest[]

  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
  @@map("services")
}

model ServiceRequest {
  id           String      @id @default(uuid())
  requestNo    String      @unique // NSX-2025-001234
  userId       String?
  serviceId    String
  assignedToId String?
  isGuest      Boolean     @default(true)
  guestName    String?
  guestEmail   String?
  guestPhone   String?
  guestAddress String?
  guestSource  GuestSource @default(REFERRAL)

  status     RequestStatus @default(SUBMITTED)
  formData   Json // captured at submission, immutable snapshot
  userNotes  String? // optional notes from user at submission
  adminNotes String? // internal notes, not visible to user

  // Pricing
  quotedPrice     Decimal? @db.Decimal(10, 2)
  finalPrice      Decimal? @db.Decimal(10, 2)
  currency        String   @default("BDT")
  deliveryMessage String?

  // Timestamps
  submittedAt DateTime  @default(now())
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user       UserDetails? @relation("UserRequests", fields: [userId], references: [id])
  assignedTo UserDetails? @relation("AssignedManager", fields: [assignedToId], references: [id])
  service    Service      @relation(fields: [serviceId], references: [id])

  payment       Payment?
  statusHistory RequestStatusHistory[]
  documents     RequestDocument[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([userId])
  @@index([serviceId])
  @@index([assignedToId])
  @@index([status])
  @@index([requestNo])
  @@index([createdAt])
  @@index([userId, status])
  @@map("service_requests")
}

model RequestStatusHistory {
  id          String         @id @default(uuid())
  requestId   String
  changedById String
  action      ActionType?
  fromStatus  RequestStatus?
  toStatus    RequestStatus
  note        String?
  createdAt   DateTime       @default(now())

  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  changedBy UserDetails    @relation("ChangedBy", fields: [changedById], references: [id])

  @@index([requestId])
  @@index([createdAt])
  @@map("request_status_history")
}

model RequestDocument {
  id             String   @id @default(uuid())
  requestId      String
  uploadedById   String
  uploadedByRole Role
  name           String
  originalName   String
  url            String // S3 URL
  key            String // S3 key for deletion
  mimeType       String
  size           Int // bytes
  description    String? // e.g. "Payment screenshot", "Existing CV"
  createdAt      DateTime @default(now())

  request    ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy UserDetails    @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([requestId])
  @@index([uploadedById])
  @@map("request_documents")
}
