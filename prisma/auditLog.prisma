model AuditLog {
  id           String     @id @default(uuid())
  performedById String
  requestId    String?
  action       ActionType
  entityType   String     // "ServiceRequest" | "Payment" | "User" | "Service"
  entityId     String
  oldValue     Json?
  newValue     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())

  performedBy UserDetails            @relation("PerformedBy", fields: [performedById], references: [id])
  request     ServiceRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([performedById])
  @@index([requestId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}